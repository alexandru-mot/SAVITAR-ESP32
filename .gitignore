# ==============================================================================
# PlatformIO .gitignore Template
# ==============================================================================

# PlatformIO core and build directories
.pio/
.pioenvs/
.piolibdeps/

# ------------------------------------------------------------------------------
# IDE and Editor Files
# ------------------------------------------------------------------------------

# VSCode settings generated by PlatformIO
# (PlatformIO automatically regenerates these based on your platformio.ini)
.vscode/

# If you use other editors
.idea/
*.suo
*.sln
*.code-workspace

# ------------------------------------------------------------------------------
# Compiled Binaries and Build Artifacts
# ------------------------------------------------------------------------------
# Note: These are usually caught by the .pio/ rule above, but included 
# for safety in case of custom build scripts or exports.
*.hex
*.bin
*.elf
*.o
*.a
*.map
*.lst

# ------------------------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db